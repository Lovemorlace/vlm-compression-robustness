# ============================================
# Configuration du projet
# Copier en .env et adapter les valeurs
# ============================================

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vlm_compression
POSTGRES_USER=vlm_user
POSTGRES_PASSWORD=changeme_secure_password

# Chemins projet
PROJECT_ROOT=/home/${USER}/projet
DATA_DIR=${PROJECT_ROOT}/data
RESULTS_DIR=${PROJECT_ROOT}/inference/results

# GPU
CUDA_VISIBLE_DEVICES=0

# VLM Inference
VLM_MAX_NEW_TOKENS=2048
VLM_TEMPERATURE=0.0
VLM_PROMPT="Transcribe all visible text in this document image exactly as written, preserving the reading order from top to bottom, left to right."

# Compression JPEG
JPEG_QUALITY_FACTORS=90,70,50,30,10

# Compression Neuronale (CompressAI)
NEURAL_QUALITY_LEVELS=1,3,6
# Correspond approximativement à ~0.1, ~0.25, ~0.5 bpp selon le modèle

# Backend
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
VITE_API_URL=http://localhost:8000
